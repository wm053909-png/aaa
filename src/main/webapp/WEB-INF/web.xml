<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Book Management System 2.0</display-name>

    <!-- 应用启动监听器：初始化数据库 -->
    <listener>
        <listener-class>com.booksystem.filter.AppInitListener</listener-class>
    </listener>

    <!-- 编码过滤器 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.booksystem.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 搜索接口 -->
    <servlet>
        <servlet-name>SearchBookServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.SearchBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchBookServlet</servlet-name>
        <url-pattern>/api/search</url-pattern>
    </servlet-mapping>

    <!-- 借阅接口 -->
    <servlet>
        <servlet-name>BorrowServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.BorrowServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BorrowServlet</servlet-name>
        <url-pattern>/api/borrow</url-pattern>
    </servlet-mapping>

    <!-- 归还接口 -->
    <servlet>
        <servlet-name>ReturnServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.ReturnServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReturnServlet</servlet-name>
        <url-pattern>/api/return</url-pattern>
    </servlet-mapping>

    <!-- 分类接口 -->
    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.CategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/api/categories</url-pattern>
    </servlet-mapping>

    <!-- 读者接口 -->
    <servlet>
        <servlet-name>ReaderServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.ReaderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReaderServlet</servlet-name>
        <url-pattern>/api/readers</url-pattern>
    </servlet-mapping>

    <!-- 图片上传接口 -->
    <servlet>
        <servlet-name>UploadServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.UploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadServlet</servlet-name>
        <url-pattern>/api/upload</url-pattern>
    </servlet-mapping>

    <!-- 添加图书接口 -->
    <servlet>
        <servlet-name>AddBookServlet</servlet-name>
        <servlet-class>com.booksystem.servlet.AddBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddBookServlet</servlet-name>
        <url-pattern>/api/book/add</url-pattern>
    </servlet-mapping>

    <!-- 欢迎页 -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
</web-app>
